+}
+
+/* Accent */
+.btn--accent {
+	background-color: var(--color-accent);
+	color: var(--color-contrast);
+	border-color: var(--color-accent);
+}
+
+.btn--accent:hover {
+	background-color: #f0de00;
+	border-color: #f0de00;
+}
+
+/* WordPress core button */
+.wp-block-button__link,
+.button,
+input[type="submit"],
+button[type="submit"] {
