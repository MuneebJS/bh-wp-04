+}
+
+.entry-content .alignleft {
+	float: left;
+	margin: var(--space-2) var(--space-6) var(--space-4) 0;
+}
+
+.entry-content .alignright {
+	float: right;
+	margin: var(--space-2) 0 var(--space-4) var(--space-6);
+}
+
+.entry-content .aligncenter {
+	margin-inline: auto;
+	text-align: center;
