+
+.archive-description p:last-child {
+	margin-bottom: 0;
+}
+
+
+/* ==========================================================================
+   8. Post Cards
+   ========================================================================== */
+
+.post-card {
+	display: flex;
+	flex-direction: column;
+	background-color: var(--color-base);
