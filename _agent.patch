+	gap: var(--space-6);
+}
+
+.post-navigation .nav-previous,
+.post-navigation .nav-next {
+	display: flex;
+}
+
+.post-navigation .nav-next {
+	justify-content: flex-end;
+	text-align: right;
+}
+
+.post-navigation a {
+	display: inline-flex;
+	flex-direction: column;
+	gap: var(--space-1);
+	padding: var(--space-4) var(--space-5);
+	background-color: var(--color-surface);
+	border: 1px solid var(--color-border);
