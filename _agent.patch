+
+.post-card .post-thumbnail {
+	aspect-ratio: 16 / 9;
+	overflow: hidden;
+}
+
+.post-card .post-thumbnail a {
+	display: block;
+	height: 100%;
+}
+
+.post-card .post-thumbnail__img {
+	width: 100%;
+	height: 100%;
+	object-fit: cover;
+	transition: transform var(--transition-slow);
+}
+
+.post-card:hover .post-thumbnail__img {
