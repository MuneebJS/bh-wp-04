+	color: #fff;
+}
+
+
+/* ==========================================================================
+   10. Single Post
+   ========================================================================== */
+
+.single-post .entry-header {
+	margin-bottom: var(--space-8);
+}
+
+.single-post .entry-title {
+	font-size: var(--font-size-3xl);
+}
+
+.single-post .post-thumbnail {
