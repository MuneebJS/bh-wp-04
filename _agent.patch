+}
+
+.post-card__body .entry-summary p:last-child {
+	margin-bottom: 0;
+}
+
+
+/* ==========================================================================
+   9. Entry Meta
+   ========================================================================== */
+
+.entry-meta {
+	display: flex;
+	flex-wrap: wrap;
+	align-items: center;
+	gap: var(--space-2);
